# Copy to .env and fill in values. Dokploy reads this same file when set as
# the project's environment source.

# Shared bearer token. Generate with: openssl rand -hex 32
# The same value must be set as BENCHMARK_WORKER_SECRET on jsperf.app (Vercel).
BENCHMARK_WORKER_SECRET=change-me-to-a-32-byte-hex-string

# Set to 0 to skip wrapping benchmark runs with `perf stat`.
# Useful when the host kernel rejects PERFMON / SYS_PTRACE (some Hostinger
# kernels). Leaving it at 1 is harmless: missing counters render as "—".
COLLECT_PERF=1
