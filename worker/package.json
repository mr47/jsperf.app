{
  "name": "jsperf-worker",
  "version": "0.1.0",
  "description": "Multi-runtime benchmark worker for jsperf.net. Runs Node/Deno/Bun benchmarks in resource-isolated Docker containers.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "build-images": "./scripts/build-images.sh",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.16.0",
    "hono": "^4.10.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
