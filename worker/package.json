    "dev": "node --watch server.js",
    "build-images": "./scripts/build-images.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.10.0",
    "@hono/node-server": "^1.16.0"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
