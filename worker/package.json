{
  "name": "jsperf-worker",
  "version": "0.1.0",
  "description": "Multi-runtime benchmark worker for jsperf.net. Runs Node/Deno/Bun benchmarks in resource-isolated Docker containers.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build-images": "./scripts/build-images.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.16.0",
    "hono": "^4.10.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
